<Window x:Class="ELRSWifiJoystick.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:local="clr-namespace:ELRSWifiJoystick"
        Title="ELRS / TBS Crossfire WiFi Joystick"
        Width="740" Height="820" MinWidth="660" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Icon="/icons/app.ico"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- banner -->
            <RowDefinition Height="Auto" />   <!-- axes -->
            <RowDefinition Height="Auto" />   <!-- stats -->
            <RowDefinition Height="Auto" />   <!-- firewall -->
            <RowDefinition Height="Auto" />   <!-- settings -->
            <RowDefinition Height="*" />      <!-- log -->
        </Grid.RowDefinitions>

        <!-- tray icon (non-visual) -->
        <tb:TaskbarIcon x:Name="Tray"
                        IconSource="/icons/app.ico"
                        ToolTipText="{Binding TrayText}"
                        TrayMouseDoubleClick="Tray_DoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show" Click="TrayShow_Click" />
                    <MenuItem Header="Exit" Click="TrayExit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- ===== status banner ===== -->
        <Border Grid.Row="0" Padding="18,12,12,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource BannerGray}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding State}" Value="Streaming">
                            <Setter Property="Background" Value="{StaticResource BannerGreen}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding State}" Value="Searching">
                            <Setter Property="Background" Value="{StaticResource BannerOrange}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding State}" Value="Error">
                            <Setter Property="Background" Value="{StaticResource BannerRed}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock Text="{Binding BannerTitle}" FontFamily="Segoe UI Semibold"
                           FontSize="22" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="{Binding BannerDetail}" FontSize="12.5" Margin="2,4,0,0"
                           Foreground="#FFE8E8E8" />
            </StackPanel>
        </Border>

        <!-- ===== axis bars ===== -->
        <ItemsControl Grid.Row="1" Margin="16,14,16,4" ItemsSource="{Binding Axes}"
                      IsTabStop="False" Focusable="False">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type local:AxisItem}">
                    <Grid Height="34" Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="112" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center" FontSize="13" />
                        <ProgressBar Grid.Column="1" Style="{StaticResource AxisBar}"
                                     Value="{Binding Value, Mode=OneWay}" Margin="0,5" />
                        <TextBlock Grid.Column="2" Text="{Binding PercentText}"
                                   Foreground="{StaticResource FgBrush}" FontSize="13"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ===== stats row ===== -->
        <Grid Grid.Row="2" Margin="16,4,16,0">
            <TextBlock Text="{Binding StatsText}" Foreground="{StaticResource FgBrush}"
                       FontSize="13" HorizontalAlignment="Left" VerticalAlignment="Center" />
            <TextBlock Text="{Binding VJoyText}" Foreground="{StaticResource MutedBrush}"
                       FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <!-- ===== firewall row ===== -->
        <Grid Grid.Row="3" Margin="16,8,16,0" MinHeight="32">
            <TextBlock VerticalAlignment="Center" FontSize="13" HorizontalAlignment="Left">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="Firewall may block joystick data — click to allow →" />
                        <Setter Property="Foreground" Value="{StaticResource FwWarnBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FirewallOk}" Value="True">
                                <Setter Property="Text" Value="Firewall: allowed ✓  joystick data can get through" />
                                <Setter Property="Foreground" Value="{StaticResource FwOkBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <Button Content="Allow in Firewall" Command="{Binding FixFirewallCommand}"
                    HorizontalAlignment="Right" MinWidth="150">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                        <Setter Property="Background" Value="#FFC88220" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FirewallOk}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- ===== settings row ===== -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="16,10,16,0">
            <TextBlock Text="Port:" Foreground="{StaticResource MutedBrush}"
                       VerticalAlignment="Center" FontSize="13" Margin="0,0,6,0" />
            <TextBox Width="64" Style="{StaticResource DarkTextBox}"
                     Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsPortEditable}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding ApplyPortCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <TextBlock Text="Module IP:" Foreground="{StaticResource MutedBrush}"
                       VerticalAlignment="Center" FontSize="13" Margin="14,0,6,0" />
            <TextBox Width="132" Style="{StaticResource DarkTextBox}"
                     Text="{Binding ModuleIp, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding ConnectCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <Button Content="Connect" Command="{Binding ConnectCommand}"
                    Style="{StaticResource DarkButton}" Margin="12,0,0,0" MinWidth="84" />
            <Button Command="{Binding StartStopCommand}" Style="{StaticResource DarkButton}"
                    Margin="8,0,0,0" MinWidth="74">
                <Button.Content>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Start" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="Stop" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button.Content>
            </Button>
            <Button Content="Help" Command="{Binding HelpCommand}"
                    Style="{StaticResource DarkButton}" Margin="8,0,0,0" MinWidth="68" />
        </StackPanel>

        <!-- ===== log ===== -->
        <TextBox x:Name="LogBox" Grid.Row="5" Margin="16,12,16,14"
                 Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                 Background="{StaticResource LogBgBrush}" Foreground="{StaticResource LogFgBrush}"
                 BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                 FontFamily="Consolas" FontSize="12" Padding="6,4"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                 TextWrapping="Wrap" TextChanged="LogBox_TextChanged" />
    </Grid>
</Window>
